{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE v\\d+\\.\\d+\\.\\d+\\s+ready",
          "endsPattern": "Local:\\s+https?://localhost:\\d+/?"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "lint",
      "type": "npm",
      "script": "lint",
      "group": "test",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "preview",
      "type": "npm",
      "script": "preview",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "install (pnpm)",
      "type": "shell",
      "command": "pnpm install",
      "problemMatcher": []
    }
  ]
}
